{
  "name": "kuma",
  "private": true,
  "version": "0.3.22",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "node scripts/run-tauri.mjs",
    "setup": "node scripts/safe-install.mjs",
    "sidecar:kill": "node scripts/kill-sidecars.mjs",
    "sidecar:build": "pnpm run sidecar:kill && cd python-core && node -e \"require('child_process').execSync((process.platform==='win32'?'python':'python3')+' build_sidecar.py',{stdio:'inherit'})\"",
    "sidecar:build:onedir": "cd python-core && node -e \"require('child_process').execSync((process.platform==='win32'?'python':'python3')+' build_sidecar.py',{stdio:'inherit'})\"",
    "sidecar:hash": "node scripts/sidecar-hash.mjs",
    "build:all": "pnpm run sidecar:build && pnpm run sidecar:hash && pnpm run tauri build",
    "smoke:ui": "node scripts/ui-smoke.mjs",
    "sync:check": "node scripts/sync-check.mjs",
    "i18n:lint": "node scripts/i18n-lint.mjs",
    "i18n:parity": "node scripts/i18n-parity.mjs",
    "i18n:check": "node scripts/i18n-lint.mjs && node scripts/i18n-parity.mjs",
    "gen:models": "node scripts/gen-models.mjs",
    "gen:models:check": "node scripts/gen-models.mjs --check",
    "capture-guide": "tsx --tsconfig tsconfig.scripts.json scripts/capture-guide.ts",
    "record-tutorial": "tsx --tsconfig tsconfig.scripts.json scripts/record-tutorial.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.12",
    "@tanstack/react-table": "^8.20.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "~2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.10",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.7",
    "react-resizable-panels": "^2.1.9",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tauri-apps/cli": "~2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.0",
    "jsdom": "^26.1.0",
    "json-schema-to-typescript": "^15.0.4",
    "playwright": "^1.49.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
