{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri-v2.json",
  "productName": "kuma",
  "version": "0.9.4",
  "identifier": "com.gyuminlee.kuma",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "kuma",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://github.com https://*.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "deb",
      "appimage",
      "dmg"
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    },
    "resources": {
      "samples/sample_evolvepro.csv": "samples/sample_evolvepro.csv",
      "samples/sample_plasmid.gb": "samples/sample_plasmid.gb",
      "samples/egfp.fa": "samples/egfp.fa",
      "samples/sample_multi_evolve.csv": "samples/sample_multi_evolve.csv",
      "samples/mame/reference.fasta": "samples/mame/reference.fasta",
      "samples/mame/03_mame_expected_mutations.xlsx": "samples/mame/03_mame_expected_mutations.xlsx",
      "samples/mame/04_mame_custom_barcodes.xlsx": "samples/mame/04_mame_custom_barcodes.xlsx",
      "samples/mame/05_mame_sample_map.xlsx": "samples/mame/05_mame_sample_map.xlsx",
      "samples/mame/06_mame_plate_layout.xlsx": "samples/mame/06_mame_plate_layout.xlsx",
      "samples/mame/07_mame_activity_long.csv": "samples/mame/07_mame_activity_long.csv",
      "samples/mame/07_mame_activity_long.xlsx": "samples/mame/07_mame_activity_long.xlsx",
      "samples/mame/08_mame_evolvepro_raw.xlsx": "samples/mame/08_mame_evolvepro_raw.xlsx",
      "samples/mame/09_mame_agilent_rep_batch.xlsx": "samples/mame/09_mame_agilent_rep_batch.xlsx",
      "samples/mame/10_mame_gc_prenormalised.xlsx": "samples/mame/10_mame_gc_prenormalised.xlsx",
      "resources/NOTICE.md": "resources/NOTICE.md",
      "sidecar-hashes.json": "sidecar-hashes.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/kuro-sidecar",
      "binaries/mame-sidecar"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/gyuminlee-repo/KURO/releases/latest/download/latest.json"
      ]
    }
  }
}
