{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri-v2.json",
  "productName": "kuma",
  "version": "0.2.3",
  "identifier": "com.gyuminlee.kuma",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "kuma",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "deb",
      "appimage",
      "dmg"
    ],
    "resources": {
      "samples/sample_evolvepro.csv": "samples/sample_evolvepro.csv",
      "samples/sample_plasmid.gb": "samples/sample_plasmid.gb",
      "samples/sample_multi_evolve.csv": "samples/sample_multi_evolve.csv"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/kuro-sidecar",
      "binaries/mame-sidecar"
    ]
  }
}
