{
  "identifier": "default",
  "description": "Default capabilities for KURO",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/kuro-sidecar",
          "sidecar": true
        }
      ]
    }
  ]
}
