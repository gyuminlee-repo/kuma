{
  "identifier": "default",
  "description": "Default capabilities for KURO",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-stdin-write",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/kuro-sidecar",
          "sidecar": true
        }
      ]
    }
  ]
}
