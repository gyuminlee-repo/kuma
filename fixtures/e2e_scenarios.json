[
  {
    "id": "scenario_1_basic_pcr",
    "title": "Basic PCR — ispS full gene amplification",
    "description": "Amplify full ispS CDS with Q5 for cloning",
    "steps": [
      {"rpc": "list_polymerases", "params": {}, "expect": "array of 18+ profiles"},
      {"rpc": "get_polymerase_details", "params": {"name": "Q5 High-Fidelity"}, "expect": "profile with opt_tm=72"},
      {"rpc": "design_primers", "params": {
        "sequence": "",
        "target_start": 0,
        "target_length": 1788,
        "polymerase": "Q5 High-Fidelity",
        "num_return": 5
      }, "expect": "1-5 primer pairs, product_size ~1788"}
    ]
  },
  {
    "id": "scenario_2_gibson_cloning",
    "title": "Gibson Assembly — ispS into pET-28a",
    "description": "Design primers with 21 bp homology arms for Gibson Assembly",
    "steps": [
      {"rpc": "design_primers", "params": {
        "sequence": "",
        "target_start": 0,
        "target_length": 1788,
        "polymerase": "Q5 High-Fidelity",
        "num_return": 3,
        "fwd_overhang": "CAGCAAATGGGTCGCGGATCC",
        "rev_overhang": "GTGGTGGTGGTGGTGCTCGAG"
      }, "expect": "pairs with overhang fields populated, full_sequence = overhang + binding"}
    ]
  },
  {
    "id": "scenario_3_colony_pcr",
    "title": "Colony PCR — ispS internal check",
    "description": "Quick colony PCR with Taq to verify insert",
    "steps": [
      {"rpc": "design_primers", "params": {
        "sequence": "",
        "target_start": 400,
        "target_length": 300,
        "polymerase": "Taq (NEB)",
        "num_return": 3
      }, "expect": "pairs with product_size ~300, lower Tm than Q5"}
    ]
  },
  {
    "id": "scenario_4_custom_polymerase",
    "title": "Custom polymerase — save and use",
    "description": "Register custom polymerase then design primers with it",
    "steps": [
      {"rpc": "save_custom_polymerase", "params": {
        "name": "Lab Custom Taq",
        "manufacturer": "In-house",
        "fidelity": "standard",
        "tm_method": "breslauer",
        "salt_correction": "schildkraut",
        "opt_tm": 55.0,
        "min_tm": 50.0,
        "max_tm": 62.0,
        "opt_size": 20,
        "min_size": 18,
        "max_size": 28,
        "min_gc": 30.0,
        "max_gc": 70.0,
        "salt_monovalent": 50.0,
        "salt_divalent": 1.5,
        "dntp_conc": 0.2,
        "dna_conc": 200.0,
        "max_tm_diff": 5.0
      }, "expect": "status ok"},
      {"rpc": "design_primers", "params": {
        "sequence": "",
        "target_start": 400,
        "target_length": 300,
        "polymerase": "Lab Custom Taq",
        "num_return": 3
      }, "expect": "primers designed with breslauer Tm method"}
    ]
  },
  {
    "id": "scenario_5_lambda_red",
    "title": "Lambda Red recombineering — long homology arms",
    "description": "50 bp homology arms for chromosomal integration",
    "steps": [
      {"rpc": "design_primers", "params": {
        "sequence": "",
        "target_start": 0,
        "target_length": 1788,
        "polymerase": "Q5 High-Fidelity",
        "num_return": 3,
        "fwd_overhang": "ATGAAACCCATTAGCGATCGTCGTCTGACCGATCTGCTGAACAGCGAAG",
        "rev_overhang": "TTACGCCAGAATGCGTTTTCGTCTTCGCTGATGCGATCTTCCAGCTTGC"
      }, "expect": "~50 bp overhangs on each primer"}
    ]
  }
]
